# ── Entorno / secretos ──
.env

# ── Python ──
__pycache__/
*.pyc

# ── Frontend (dashboard) ──
dashboard/node_modules/
dashboard/dist/

# ── Datos en runtime (viven en PostgreSQL, no en el repo) ──
memoria.json
ventas.xlsx
BASE_DE_DATOS_PRODUCTOS.xlsx

# ── Material local / legacy (solo en la máquina) ──
legacy/

# ── Claude Code / claude-mem (estado local de desarrollo) ──
.claude-mem/
.claude-mem.db
.claude-mem.sqlite
.claude/plugins/
.claude/local/
.claude/*.lock

# ── Obsidian (notas locales, no van al repo) ──
.obsidian/
*.canvas
*.base

# ── Documentos binarios sueltos (no versionar) ──
*.docx
