# ════════════════════════════════════════════════════════════════════════════
# FerreBot — variables de entorno (plantilla)
# Copia a .env y completa. En Railway se configuran en el panel del servicio.
# Para clonar una ferretería nueva: completa el núcleo + identidad, y activa solo
# los módulos que use (los flags se autodetectan por sus credenciales).
# ════════════════════════════════════════════════════════════════════════════

# ── Núcleo (obligatorias) ────────────────────────────────────────────────────
TELEGRAM_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DATABASE_URL=
SECRET_KEY=                      # JWT (mínimo 32 chars)
WEBHOOK_URL=                     # URL pública del bot (modo webhook)
SERVICE_TYPE=api                 # 'bot' o 'api' (Railway lo define por servicio)
CORS_ORIGIN=                     # URL del dashboard (sin esto el front no conecta)
# PORT lo inyecta Railway

# ── Identidad del negocio (se usa en facturación DIAN y cuentas de cobro) ─────
EMPRESA_NOMBRE=Ferretería Punto Rojo F.D
EMPRESA_NIT=1235046119-1
EMPRESA_CIUDAD=Cartagena, Bolívar

# ── Feature flags ─────────────────────────────────────────────────────────────
# Si NO se setean, se autodetectan por la credencial del módulo (presente=on).
# Setear explícitamente a true/false para forzar. Valores: true|false.
# FE_HABILITADA=
# HONORARIOS_HABILITADO=
# BANCOLOMBIA_HABILITADO=
# BOLD_HABILITADO=
# WOMPI_HABILITADO=
# GMAIL_COMPRAS_HABILITADO=
# CLOUDINARY_HABILITADO=
# IA_MEMORIA_AVANZADA=true        # compresor nocturno (default true)
# INVENTARIO_HABILITADO=true      # default true
# CAJA_HABILITADA=true            # default true
# FIADOS_HABILITADO=true          # default true

# ── Facturación electrónica DIAN (MATIAS API) — si FE_HABILITADA ──────────────
MATIAS_EMAIL=
MATIAS_PASSWORD=
MATIAS_RESOLUTION=
MATIAS_PREFIX=
MATIAS_NUM_DESDE=1
MATIAS_RESOLUTION_DSNO=
MATIAS_DS_NUM_DESDE=1
# MATIAS_API_URL=https://api-v2.matias-api.com/api/ubl2.1
# MATIAS_AMBIENTE=produccion       # produccion|pruebas
# IDs internos de MATIAS (NO son códigos DANE — ver CLAUDE.md §10)
MATIAS_CITY_ID=149
MATIAS_POSTAL_CODE=130001
MATIAS_COUNTRY_ID=45

# ── Honorarios (Cuenta de Cobro + Documento Soporte) — si HONORARIOS_HABILITADO ─
HONORARIOS_VALOR=2000000
HONORARIOS_CHAT_ID=
# Proveedor que emite la CC/DS (persona natural contratista)
HONORARIOS_PROVEEDOR_NOMBRE=Andrés Felipe Malo Hernández
HONORARIOS_PROVEEDOR_NOMBRE_DIAN=MALO HERNANDEZ ANDRES FELIPE
HONORARIOS_PROVEEDOR_CC=1.043.295.412
HONORARIOS_PROVEEDOR_DNI=1043295412
HONORARIOS_PROVEEDOR_NIT=1043295412-4
HONORARIOS_PROVEEDOR_DIRECCION=CON EL REFUGIO BL 12 AP 2A
HONORARIOS_PROVEEDOR_CIUDAD=Cartagena, Bolívar
HONORARIOS_PROVEEDOR_MOBILE=3001234567
HONORARIOS_PROVEEDOR_EMAIL=andresfmalo05@gmail.com
# HONORARIOS_CONCEPTO=...
# HONORARIOS_DS_DESCRIPCION=...

# ── Cloudinary (fotos de facturas de proveedor) — si CLOUDINARY_HABILITADO ────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Gmail compras fiscales (Pub/Sub) — si GMAIL_COMPRAS_HABILITADO ────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=
GMAIL_PUBSUB_TOPIC=

# ── Bancolombia (Gmail Pub/Sub) — si BANCOLOMBIA_HABILITADO ───────────────────
BANCOLOMBIA_GMAIL_CLIENT_ID=
BANCOLOMBIA_GMAIL_CLIENT_SECRET=
BANCOLOMBIA_GMAIL_REFRESH_TOKEN=
BANCOLOMBIA_GMAIL_USER=
BANCOLOMBIA_PUBSUB_TOPIC=
BANCOLOMBIA_PUBSUB_TOKEN=

# ── Pagos Bold / Wompi (webhooks) ─────────────────────────────────────────────
BOLD_WEBHOOK_SECRET=
WOMPI_EVENTS_SECRET=
TELEGRAM_NOTIFY_CHAT_ID=

# ── Bot: autorización y rate limit ────────────────────────────────────────────
AUTHORIZED_CHAT_IDS=
# RATE_LIMIT_SEGUNDOS=2
# RATE_LIMIT_MAX=5
# TELEGRAM_WEBHOOK_SECRET=

# ── Observabilidad (opcional) ─────────────────────────────────────────────────
SENTRY_DSN=

# ════════════════════════════════════════════════════════════════════════════
# DASHBOARD (Vite) — se leen al hacer `npm run build`. En Railway, en el servicio API.
# Controlan branding y qué tabs se muestran (deben reflejar los flags del backend).
# ════════════════════════════════════════════════════════════════════════════
# VITE_FE_HABILITADA=true
# VITE_INVENTARIO_HABILITADO=true
# VITE_CAJA_HABILITADA=true
# VITE_BANCOLOMBIA_HABILITADO=true
