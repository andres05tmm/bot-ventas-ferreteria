{
  "$schema": "https://schema.railway.app/railway-schema-v1.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip3 install -r requirements.txt --break-system-packages && cd dashboard && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "bash run.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": {
    "bot-ventas-ferreteria": {
      "deploy": {
        "startCommand": "python3 -m uvicorn api:app --host 0.0.0.0 --port $PORT"
      }
    },
    "cooperative-embrace": {
      "deploy": {
        "startCommand": "python3 start-bot.py"
      }
    }
  }
}
